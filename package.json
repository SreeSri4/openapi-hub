{
  "name": "openapi-hub",
  "version": "1.0.0",
  "description": "Multi-tenant OpenAPI documentation hub for Cloud Foundry",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:server",
    "build:server": "tsc src/server/index.ts --outDir dist --module esnext --target es2020 --moduleResolution node",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.4",
    "swagger-ui-react": "^5.1.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
