{
  "tenants": [
    {
      "id": "MX",
      "name": "🏭 Manufacturing",
      "description": "Manufacturing Industry",
      "apis": [
        {
          "id": "mfg-users",
          "name": "User Management API",
          "description": "Authentication & user management",
          "baseUrl": "https://api.manufacturing.com/v1",
          "version": "1.0.0",
          "contact": {
            "name": "Manufacturing Support",
            "email": "support@manufacturing.com"
          },
          "license": {
            "name": "Apache 2.0"
          },
          "endpoints": [
            {
              "path": "/users",
              "method": "GET",
              "summary": "List all users",
              "description": "Retrieve a paginated list of users",
              "tags": ["Users"],
              "parameters": [
                {
                  "name": "page",
                  "in": "query",
                  "description": "Page number",
                  "required": false,
                  "schema": {
                    "type": "integer",
                    "example": 1
                  }
                },
                {
                  "name": "limit",
                  "in": "query",
                  "description": "Items per page",
                  "required": false,
                  "schema": {
                    "type": "integer",
                    "example": 20
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "Successful response",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "users": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "name": {
                                  "type": "string"
                                },
                                "email": {
                                  "type": "string",
                                  "format": "email"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            {
              "path": "/users",
              "method": "POST",
              "summary": "Create a new user",
              "description": "Create a new user in the system",
              "tags": ["Users"],
              "requestBody": {
                "description": "User details",
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string",
                          "format": "email"
                        },
                        "password": {
                          "type": "string"
                        }
                      },
                      "required": ["name", "email", "password"]
                    }
                  }
                }
              },
              "responses": {
                "201": {
                  "description": "User created successfully"
                },
                "400": {
                  "description": "Invalid request"
                }
              }
            },
            {
              "path": "/users/{id}",
              "method": "GET",
              "summary": "Get user by ID",
              "description": "Retrieve a specific user by their ID",
              "tags": ["Users"],
              "parameters": [
                {
                  "name": "id",
                  "in": "path",
                  "description": "User ID",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "User found"
                },
                "404": {
                  "description": "User not found"
                }
              }
            }
          ],
          "tags": [
            {
              "name": "Users",
              "description": "User management endpoints"
            }
          ]
        },
        {
          "id": "mfg-products",
          "name": "Product Catalog API",
          "description": "Product & inventory management",
          "baseUrl": "https://api.manufacturing.com/v1",
          "version": "1.0.0",
          "endpoints": [
            {
              "path": "/products",
              "method": "GET",
              "summary": "List all products",
              "tags": ["Products"],
              "parameters": [
                {
                  "name": "category",
                  "in": "query",
                  "description": "Product category",
                  "required": false,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "List of products"
                }
              }
            },
            {
              "path": "/products/{id}",
              "method": "GET",
              "summary": "Get product by ID",
              "tags": ["Products"],
              "parameters": [
                {
                  "name": "id",
                  "in": "path",
                  "description": "Product ID",
                  "required": true,
                  "schema": {
                    "type": "string"
                  }
                }
              ],
              "responses": {
                "200": {
                  "description": "Product details"
                },
                "404": {
                  "description": "Product not found"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "price-staging-hub",
      "name": "📊 Price Staging Hub",
      "description": "Price Staging and Catalog Calculations Environment",
      "apis": [
        {
          "id": "get-catalog-prices-api",
          "name": "GetCatalogPrices API",
          "description": "Price Catalog REST functions",
          "baseUrl": "https://api.pricestaging.com/v1",
          "version": "1.0.0",
          "endpoints": [
            {
              "path": "/GetCatalogPrices",
              "method": "POST",
              "summary": "Get Catalog Prices",
              "description": "Fetches calculated pricing, deals, and promotional structures",
              "tags": ["GetCatalogPrices"],
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "Header": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "PricingDate": { "type": "string", "format": "YYYY-MM-DD" },
                              "Division": { "type": "string" },
                              "CustomerID": { "type": "string" },
                              "SalesOrganization": { "type": "string" },
                              "DistributionChannel": { "type": "string" },
                              "Currency": { "type": "string" },
                              "Items": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "ItemID": { "type": "string" },
                                    "Quantity": { "type": "string" },
                                    "Unit": { "type": "string" }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Success",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "GetCatalogPrices": {
                            "type": "object",
                            "properties": {
                              "Header": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "Error": { "type": "string" },
                                    "PricingDate": { "type": "string", "format": "YYYY-MM-DD" },
                                    "Division": { "type": "string" },
                                    "CustomerID": { "type": "string" },
                                    "SalesOrganization": { "type": "string" },
                                    "DistributionChannel": { "type": "string" },
                                    "Currency": { "type": "string" },
                                    "Items": {
                                      "type": "array",
                                      "items": {
                                        "type": "object",
                                        "properties": {
                                          "Error": { "type": "string" },
                                          "ItemID": { "type": "string" },
                                          "Quantity": { "type": "string" },
                                          "Unit": { "type": "string" },
                                          "Currency": { "type": "string" },
                                          "Price": { "type": "string" },
                                          "TotalPromotions": { "type": "string" },
                                          "Calculations": {
                                            "type": "array",
                                            "items": {
                                              "type": "object",
                                              "properties": {
                                                "Error": { "type": "string" },
                                                "CalculationElement": { "type": "string" },
                                                "ConditionRecord": { "type": "string" },
                                                "CalculationRate": { "type": "string" },
                                                "CalculationRateUnit": { "type": "string" },
                                                "Per": { "type": "string" },
                                                "PerUnit": { "type": "string" },
                                                "CalculationValue": { "type": "string" },
                                                "CalculationValueUnit": { "type": "string" },
                                                "InternalDealID": { "type": "string" }
                                              }
                                            }
                                          },
                                          "Deals": {
                                            "type": "array",
                                            "items": {
                                              "type": "object",
                                              "properties": {
                                                "Error": { "type": "string" },
                                                "ExternalDealID": { "type": "string" },
                                                "InternalDealID": { "type": "string" },
                                                "DealDescription": { "type": "string" },
                                                "DealAmount": { "type": "string" },
                                                "DealCurrency": { "type": "string" },
                                                "DealValidFrom": { "type": "string", "format": "YYYY-MM-DD" },
                                                "DealValidTo": { "type": "string", "format": "YYYY-MM-DD" }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "206": { "description": "Partially Processed" },
                "400": { "description": "Bad Request" },
                "401": { "description": "Unauthorized" },
                "404": { "description": "Not Found" },
                "500": { "description": "Internal Server Error" },
                "502": { "description": "Gateway Error" }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "wholesale-distribution",
      "name": "🚚 Wholesale Distribution",
      "description": "Wholesale logistics and partner shipping distribution channels",
      "apis": []
    }
  ]
}